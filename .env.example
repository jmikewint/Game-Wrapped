# PostgreSQL connection string. Use a pooled connection string in production.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/gamewrapped?schema=public"

# Steam Web API key — get one at https://steamcommunity.com/dev/apikey
# For local development, "localhost" is accepted as the domain on that form.
STEAM_API_KEY=""

# The public URL of this app. Used to build the Steam OpenID return_to/realm
# and to construct redirect URLs. Must exactly match what you sign in from.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Long random string used to sign session cookies. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=""
